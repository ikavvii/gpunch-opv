# ─── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── MongoDB Atlas ──────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/gpunch?retryWrites=true&w=majority

# ─── JWT ────────────────────────────────────────────────────────────────────────
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# ─── Email (Nodemailer / Gmail App Password) ────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
OTP_FROM=GPunch <your_email@gmail.com>

# ─── Admin Bootstrap ─────────────────────────────────────────────────────────
ADMIN_SEED_SECRET=replace_with_a_long_random_seed_secret

# ─── OTP ─────────────────────────────────────────────────────────────────────────
OTP_EXPIRY_MINUTES=10
